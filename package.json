{
  "name": "@keepchill/node-sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the KeepChill watermark API.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "gen/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "generate": "../scripts/generate-sdks.sh node",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test:coverage && npm run build"
  },
  "keywords": [
    "keepchill",
    "watermark",
    "sdk",
    "api"
  ],
  "author": "KeepChill <support@keepchill.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atcervanteskc/kc-node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/atcervanteskc/kc-node-sdk/issues"
  },
  "homepage": "https://keepchill.io",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
